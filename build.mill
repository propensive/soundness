object xenophile extends Library:
  object core extends Component(gossamer.core, prepositional.core, gigantism.core, fulminate.core,
    vacuous.core):
    override def scalacOptions = Task:
      settings.cc(super.scalacOptions() ++ Seq("-Yno-predef", "-Yimports:java.lang,scala,proscenium"))
  object typescript extends Component(core):
    override def scalacOptions = Task:
      settings.cc(super.scalacOptions() ++ Seq("-Yno-predef", "-Yimports:java.lang,scala,proscenium"))
  // The platform-neutral C front end (the `Native` ecosystem type markers and the `CHeaderDialect`
  // header parser); shared by the JVM Panama backend and the Scala Native backend, so it carries no
  // platform runtime and cross-compiles to both.
  object cffi extends Component(core):
    override def scalaJs = false // no JS relevance (its consumers are the native/Panama backends)
    override def scalaNative = true // but it is the shared front end of the native backend
    override def scalacOptions = Task:
      settings.cc(super.scalacOptions() ++ Seq("-Yno-predef", "-Yimports:java.lang,scala,proscenium"))
  object native extends Component(core, cffi):
    override def scalaJs = false // native FFI via `java.lang.foreign` (Panama) — JVM-only (native
                                 // uses `scalanative`); `scalaNative` follows `scalaJs` here
    override def scalacOptions = Task:
      settings.cc(super.scalacOptions() ++ Seq("-Yno-predef", "-Yimports:java.lang,scala,proscenium"))
  // The Scala Native materializer: lowers a C `Foreign` navigation to a `dlsym`+`CFuncPtr` call.
  // Compiled for the JVM (where the macro runs) and cross-compiled for native (where downstream
  // callers link it). Its `invoke` extension collides by design with `wasm`/`js` (they target
  // different platforms), so — like `js` — it is not bundled into the `test` module.
  object scalanative extends Component(core, cffi):
    override def scalaJs = false // a Scala Native materializer; no JS relevance
    override def scalaNative = true // but it is, of course, the native materializer itself
    // The native variant additionally compiles `src/nativeruntime` — the Scala Native twins of
    // the Panama module's runtime surface (`ForeignBuffer`, `ForeignLibrary.register`), which
    // reference `scala.scalanative.*` and so cannot join this module's JVM (macro) compilation.
    override def nativeSources = Task.Sources(moduleDir, moduleDir / os.up / "nativeruntime")
    override def scalacOptions = Task:
      settings.cc(super.scalacOptions() ++ Seq("-Yno-predef", "-Yimports:java.lang,scala,proscenium"))
  object wit extends Component(core, hypotenuse.core):
    override def scalacOptions = Task:
      settings.cc(super.scalacOptions() ++ Seq("-Yno-predef", "-Yimports:java.lang,scala,proscenium"))
  object webidl extends Component(core, hypotenuse.core):
    override def scalacOptions = Task:
      settings.cc(super.scalacOptions() ++ Seq("-Yno-predef", "-Yimports:java.lang,scala,proscenium"))
  object wasm extends Component(core, wit, hypotenuse.core, anticipation.codec, distillate.core,
    gossamer.core, prepositional.core):
    override def scalacOptions = Task:
      settings.cc(super.scalacOptions() ++ Seq("-Yno-predef", "-Yimports:java.lang,scala,proscenium"))
  // The JavaScript materializer: emits Scala.js dynamic calls for WebIDL/TypeScript navigations.
  // The `invoke` extension it exports collides by design with `wasm`'s (they target different
  // Scala.js link outputs), so it is not bundled into the `test` module alongside `wasm`.
  object js extends Component(core, hypotenuse.core, anticipation.codec, distillate.core,
    gossamer.core, prepositional.core):
    override def scalacOptions = Task:
      super.scalacOptions() ++ Seq("-Yno-predef", "-Yimports:java.lang,scala,proscenium")
  object test extends Tests(typescript, native, wit, webidl, wasm, hellenism.core):
    override def scalacOptions = Task:
      settings.cc(super.scalacOptions())

