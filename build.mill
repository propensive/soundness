package build

import mill.*
import mill.api.Result
import scalalib.*
import mill.scalajslib.*
import mill.scalajslib.api.*
import publish.*
import os.Path

object settings:
  // The Scala compiler is the propensive/scala fork: the 3.9.0-RC1 tree merged with the
  // capture-checking fix branches (the stock compiler mis-boxes pure values, mishandles quote
  // type-holes, alias and context-result capabilities, cast type-arguments, and cycles on JDK 25
  // sealed-classfile parsing — see rep/DECISIONS.md). It is consumed in one of two modes:
  //
  //   1. Released (the default). The fork is published at
  //      https://github.com/propensive/proscala/releases; each release ships a single
  //      `proscala-<tag>.tar.gz` asset whose contents are a `lib` directory (the unversioned core
  //      jars plus the versioned third-party jars). The `toolchain` module below downloads
  //      `SOUNDNESS_SCALA_RELEASE` (default `3.9.0-RC1-p3`, the latest in the 3.9.0 stream) and
  //      extracts it into a shared cache, exposing its jars to every coursier resolution — no
  //      local compiler build and no publishing step needed. Switch streams by setting
  //      `SOUNDNESS_SCALA_RELEASE` (e.g. `3.10.0-dev-p2`).
  //
  //   2. Local (fork developers). Point `SOUNDNESS_SCALA_HOME` at a `make`-built `release`
  //      directory to use its `release/lib` jars directly instead of downloading. After
  //      rebuilding the compiler, run `./mill clean`: the compiler and sbt-bridge paths are
  //      content-hashed, but coursier may serve other repo artifacts from its cache under this
  //      unchanging version string.
  //
  // `scalaVersion` is the *coordinate* version the toolchain force-versions every artifact to; it
  // must match the version string the jars were built with (`compiler.properties`), or
  // coursier/zinc caches poison each other across compilers. The release tag
  // (`SOUNDNESS_SCALA_RELEASE`) is a separate concept: `3.9.0-RC1-p3` ships jars built as
  // `3.9.0-RC1-propensive`. Override the coordinate with `SOUNDNESS_SCALA_VERSION` (e.g. the
  // 3.10.0 row is version "3.10.0-propensive").
  val scalaVersion = sys.env.getOrElse("SOUNDNESS_SCALA_VERSION", "3.9.0-RC1-propensive")
  val scalaRelease = sys.env.getOrElse("SOUNDNESS_SCALA_RELEASE", "3.9.0-RC1-p3")
  // Empty by default → download `scalaRelease`. Set to a local `release` directory to use its
  // `release/lib` jars directly (fork-developer mode).
  val scalaHome = sys.env.getOrElse("SOUNDNESS_SCALA_HOME", "")
  val scalaJsVersion = "1.22.0-wasm.4"
  // Scala Native cross-compilation. The stock published `nscplugin`/`scala3lib_native` for the
  // upstream base version work unchanged with the fork compiler (the plugin is keyed to the base
  // Scala version, and the fork stays TASTy/plugin-compatible), so — unlike the Scala.js stdlib —
  // no fork-republished Native artifacts are needed. `scalaNativeScalaVersion` is the *base*
  // version those artifacts are published for (the fork's `-propensive` suffix is dropped).
  val scalaNativeVersion = "0.5.12"
  val scalaNativeScalaVersion = "3.9.0-RC1"
  val scalaOptions = Seq(
    "-experimental",
    "-new-syntax",
    "-feature",
    "-preview",
    //"-explain",
    "-deprecation",
    "-Wunused:imports",
    "-Wimplausible-patterns",
    // Suppress `-Wunused:imports` false positives on given/capability marker imports that
    // dotty's usage tracking misses: the import is load-bearing (removing it breaks
    // compilation), so it is silenced narrowly by `origin` (the imported symbol's path).
    "-Wconf:origin=.*unsafeExceptions.canThrowAny:s",
    "-Wconf:origin=.*strategies.throwUnsafely:s",
    "-Wconf:origin=.*hashProviders.soundnessHashing:s",
    "-Wconf:origin=.*charEncoders.ascii:s",
    "-Wconf:origin=.*textMetrics.uniform:s",
    "-Wconf:origin=.*arithmeticOptions.overflow.unchecked:s",
    "-Wconf:origin=.*errorDiagnostics.empty:s",
    "-Wconf:origin=.*logging.silent:s",
    "-Wconf:origin=.*pathOnLinux:s",
    "-Wconf:origin=.*systems.java:s",
    "-Wconf:origin=.*overwritePreexisting.enabled:s",
    "-Wconf:origin=.*dynamicJsonAccess.enabled:s",
    "-Wconf:origin=.*dynamicTelAccess.enabled:s",
    "-Wconf:origin=.*queryParameters.arbitraryQueryParameter:s",
    "-Wconf:origin=.*CssClass.nominative:s",
    "-Wconf:origin=.*Async.nominative:s",
    // `frames` is deliberately `inline` so the anonymous `Iterator` expands (with the by-name
    // `frame` thunk and the caller's `Cursor` operand-type refinement) at each call site.
    "-Wconf:src=.*obligatory.Framable.*&msg=anonymous class:s",
    // `whereas` applies a deliberately-partial `PartialFunction` as a total function; the unmatched
    // exceptions are routed to the trailing `.recover`, so the match is intentionally non-exhaustive.
    "-Wconf:src=.*synesthesia.McpServer.*&msg=match may not be exhaustive:s",
    // "-Wsafe-init",
    "-Xmax-inlines", "32",
    //"-Ycc-new",
    "-Yno-flexible-types",
    "-Yexplicit-nulls",
    "-Ycheck-all-patmat",
    // "-explain-cyclic",
    "-language:experimental.modularity",
    "-language:experimental.dependent",
    "-language:experimental.relaxedLambdaSyntax",
    "-language:experimental.genericNumberLiterals",
    "-language:experimental.into",
    "-language:experimental.erasedDefinitions",
    //"-language:experimental.packageObjectValues",
    "-language:implicitConversions",
    "-language:experimental.saferExceptions",
    "-language:experimental.strictEqualityPatternMatching",
    "-language:experimental.subCases",
    "-language:experimental.multiSpreads"
  )

  val scalaOptionsCC = scalaOptions ++ Seq("-Ycc-new")

  // Append the capture-checking flags to an existing options list. Enabling capture
  // checking is being rolled out module-by-module, bottom-up through the dependency
  // graph; a module opts in by routing its `scalacOptions` through this. The language
  // flag is equivalent to a per-file `import language.experimental.captureChecking`, so
  // no source edits are needed to switch a module on.
  def cc(options: Seq[String]): Seq[String] =
    options ++ Seq("-Ycc-new", "-language:experimental.captureChecking")

  // Capture checking plus separation checking: `consume` linearity, hidden-set
  // separation and `freeze` are only diagnosed in units compiled with this flag,
  // so a module holding exclusive capabilities is not actually checked for
  // single ownership until it routes through `sep`. Rolled out module-by-module
  // like `cc`; the flag subsumes the per-file
  // `import language.experimental.separationChecking`.
  def sep(options: Seq[String]): Seq[String] =
    cc(options) :+ "-language:experimental.separationChecking"

  // Override `-Xmax-inlines` to `limit`, replacing any existing setting rather
  // than appending a second one (which the compiler reports as "Option
  // -Xmax-inlines was updated"). The base stays 32 everywhere else.
  def maxInlines(options: Seq[String], limit: String): Seq[String] =
    def strip(remaining: List[String]): List[String] = remaining match
      case "-Xmax-inlines" :: _ :: rest => strip(rest)
      case other :: rest                => other :: strip(rest)
      case Nil                          => Nil

    strip(options.to(List)) ++ Seq("-Xmax-inlines", limit)

// Exposes the fork compiler's `release/lib` jars (from a local build via `settings.scalaHome`, or
// downloaded from the `settings.scalaRelease` GitHub release) as a Maven-layout repository,
// generated on demand into the task's own dest: the unversioned jars are copied to versioned
// coordinates with minimal POMs. Everything coursier resolves for `settings.scalaVersion` — the
// unified `scala-library` (force-versioned into every module's resolution), `scala3-compiler_3`
// (including the modules that depend on the compiler API), `scala3-staging_3`, the sbt bridge, and
// the Scala.js stdlib — is served from here.
object toolchain extends Module:
  // Downloads and extracts the `settings.scalaRelease` tarball from propensive/proscala into a
  // *shared* cache dir outside the Mill `out/` tree, so the throwaway-worktree `make attest` build
  // (clean `out/` every time) reuses it and stays offline after the first fetch. Each release is a
  // single `proscala-<tag>.tar.gz` asset carrying a `lib/` directory of jars, extracted here into
  // `<tag>/lib`. A `.complete` sentinel makes a fully-populated cache a no-op — no network, no
  // GitHub API call. Returns the `lib` dir.
  def downloadRelease(tag: String): os.Path =
    val root = os.home / ".cache" / "soundness" / "proscala" / tag
    val lib = root / "lib"
    val sentinel = lib / ".complete"
    if os.exists(sentinel) then lib else
      os.makeDir.all(root)
      val api = s"https://api.github.com/repos/propensive/proscala/releases/tags/$tag"
      val json = ujson.read(os.proc("curl", "-fsSL", api).call().out.text())
      val asset = json("assets").arr.find(_("name").str.endsWith(".tar.gz")).getOrElse:
        throw new Exception(s"no .tar.gz asset on proscala release $tag")
      val name = asset("name").str
      val url = asset("browser_download_url").str
      val tarball = root / name
      if !os.exists(tarball) then
        os.proc("curl", "-fsSL", "-o", tarball.toString, url).call()
      // Verify against the published digest when the API supplies one ("sha256:<hex>").
      asset.obj.get("digest").flatMap(_.strOpt).foreach: digest =>
        if digest.startsWith("sha256:") then
          val md = java.security.MessageDigest.getInstance("SHA-256")
          val hex = md.digest(os.read.bytes(tarball)).map("%02x".format(_)).mkString
          if hex != digest.stripPrefix("sha256:") then
            os.remove(tarball)
            throw new Exception(s"checksum mismatch for $name (expected $digest, got sha256:$hex)")
      // The tarball carries a `lib/` prefix, so extracting into `<tag>` lands the jars at
      // `<tag>/lib/*.jar`. Clear any partial extract first (we only get here without the sentinel).
      os.remove.all(lib)
      os.proc("tar", "-xzf", tarball.toString, "-C", root.toString).call()
      os.remove(tarball) // reclaim ~43 MB; the sentinel guards against re-fetching
      os.write(sentinel, "")
      lib

  // Content-fingerprints the fork's jars so a rebuilt or re-released compiler regenerates the
  // repository. `SOUNDNESS_SCALA_HOME` (if set) points at a local `release`; otherwise the
  // `settings.scalaRelease` assets are downloaded and cached.
  def distribution: T[PathRef] = Task.Input:
    if settings.scalaHome.nonEmpty then PathRef(os.Path(settings.scalaHome) / "lib")
    else PathRef(downloadRelease(settings.scalaRelease))

  def repo: T[PathRef] = Task:
    val lib = distribution().path
    val v = settings.scalaVersion
    val js = settings.scalaJsVersion
    val sl = "org.scala-lang"
    val sjs = "org.scala-js"

    // (group, artifactId, jar filename in release/lib, coordinate version, dependencies as
    // (group, id, version)). The fork's own jars are versioned to the Scala coordinate `v`; the
    // Scala.js runtime jars — which the fork builds against a custom (non-Central) Scala.js and
    // ships under their own `-<jsVersion>` filenames — keep the Scala.js coordinate `js`.
    val artifacts = Seq(
      (sl, "scala-library", "scala-library.jar", v, Seq()),
      (sl, "scala3-library_3", "scala3-library.jar", v, Seq((sl, "scala-library", v))),
      (sl, "scala3-interfaces", "scala3-interfaces.jar", v, Seq()),
      (sl, "tasty-core_3", "tasty-core.jar", v, Seq((sl, "scala-library", v))),
      (sl, "scala3-compiler_3", "scala3-compiler.jar", v, Seq(
        (sl, "scala3-interfaces", v),
        (sl, "tasty-core_3", v),
        (sl, "scala3-library_3", v),
        ("org.scala-lang.modules", "scala-asm", "9.9.0-scala-1"),
        ("org.scala-sbt", "compiler-interface", "1.12.0"),
        ("org.scala-sbt", "util-interface", "1.11.5"))),
      (sl, "scala3-repl_3", "scala3-repl.jar", v, Seq(
        (sl, "scala3-compiler_3", v),
        ("org.jline", "jline-reader", "4.0.14"),
        ("org.jline", "jline-terminal", "4.0.14"),
        ("org.jline", "jline-terminal-jni", "4.0.14"),
        ("io.get-coursier", "interface", "1.0.29-M4"),
        ("org.virtuslab", "using_directives", "1.1.4"),
        ("com.lihaoyi", "pprint_3", "0.9.3"))),
      (sl, "scala3-sbt-bridge", "scala3-sbt-bridge.jar", v, Seq(
        (sl, "scala3-compiler_3", v),
        (sl, "scala3-repl_3", v))),
      (sl, "scala3-staging_3", "scala3-staging.jar", v, Seq((sl, "scala3-compiler_3", v))),
      (sl, "scala3-tasty-inspector_3", "scala3-tasty-inspector.jar", v, Seq(
        (sl, "scala3-compiler_3", v))),
      (sjs, "scalajs-javalib", s"scalajs-javalib-$js.jar", js, Seq()),
      (sjs, "scalajs-library_2.13", s"scalajs-library_2.13-$js.jar", js, Seq(
        (sjs, "scalajs-javalib", js))),
      (sjs, "scalajs-scalalib_2.13", "scalajs-scalalib_2.13.jar", v, Seq(
        (sjs, "scalajs-javalib", js))),
      (sl, "scala3-library_sjs1_3", "scala3-library_sjs1.jar", v, Seq(
        (sl, "scala-library", v),
        (sjs, "scalajs-library_2.13", js),
        (sjs, "scalajs-scalalib_2.13", v))))

    artifacts.map: (group, id, jar, version, dependencies) =>
      val dir = Task.dest / os.SubPath(group.replace('.', '/')) / id / version
      os.makeDir.all(dir)
      os.copy(lib / jar, dir / s"$id-$version.jar", replaceExisting = true)

      val deps = dependencies.map: (dGroup, dId, dVersion) =>
        s"<dependency><groupId>$dGroup</groupId><artifactId>$dId</artifactId>" +
          s"<version>$dVersion</version></dependency>"
      . mkString

      os.write.over(dir / s"$id-$version.pom",
        s"""<?xml version="1.0" encoding="UTF-8"?>
           |<project xmlns="http://maven.apache.org/POM/4.0.0">
           |  <modelVersion>4.0.0</modelVersion>
           |  <groupId>$group</groupId>
           |  <artifactId>$id</artifactId>
           |  <version>$version</version>
           |  <dependencies>$deps</dependencies>
           |</project>
           |""".stripMargin)

    PathRef(Task.dest)

// Resolves the stock Scala Native artifacts from Maven Central (they are not fork-built, so no
// local repository view is needed). `nscplugin` is the compiler plugin that lowers to NIR, added
// as a single `-Xplugin:` (resolved intransitively so no non-plugin jar is passed to `-Xplugin`,
// which the compiler rejects); `runtime` is the Native stdlib/`javalib` that `.native` sources
// compile against; `tools` is the linker library the `nativelink` driver runs in its own JVM.
object nativeToolchain extends mill.javalib.CoursierModule:
  import settings.scalaNativeVersion as snv
  import settings.scalaNativeScalaVersion as snsv

  def nscplugin: T[PathRef] = Task:
    defaultResolver().classpath(Seq(mvn"org.scala-native:nscplugin_$snsv:$snv"), false).head

  // The Native stdlib/`javalib`/C runtime. Added to each `.native` module as *compile-only*
  // dependencies (`compileMvnDeps`, which do not propagate to dependents): they carry the `.nir`
  // and bundled C sources the linker consumes, and must appear on the final link classpath exactly
  // once — routing them through `unmanagedClasspath`/`mvnDeps` instead multiplies the C runtime
  // across the module graph and the C linker then rejects the duplicate symbols.
  val runtimeDeps: Seq[mill.javalib.Dep] = Seq(
    mvn"org.scala-native:scala3lib_native0.5_3:$snsv+$snv",
    mvn"org.scala-native:javalib_native0.5_3:$snv",
    mvn"org.scala-native:auxlib_native0.5_3:$snv",
    mvn"org.scala-native:clib_native0.5_3:$snv",
    mvn"org.scala-native:posixlib_native0.5_3:$snv",
    mvn"org.scala-native:nativelib_native0.5_3:$snv")

  def tools: T[Seq[PathRef]] = Task:
    defaultResolver().classpath(Seq(mvn"org.scala-native:tools_3:$snv"))

// Routes a Scala module through the fork toolchain: the repository view above for all coursier
// resolutions, plus direct (content-hashed) paths for the two hot artifacts — the compiler
// classpath and the compiled sbt bridge — so a rebuilt compiler is picked up without any
// version-string ceremony.
trait Toolchain extends ScalaModule:
  override def repositories: T[Seq[String]] = Task:
    super.repositories() :+ s"file://${toolchain.repo().path}"

  override def scalaCompilerClasspath: T[Seq[PathRef]] = Task:
    // The fork-built jars come from the repository view because Zinc locates the standard
    // library within this classpath BY FILENAME (`scala-library-<version>*.jar`), and the
    // distribution's own filenames are unversioned. The compiler's own third-party runtime
    // dependencies (scala-asm for bytecode, the sbt compiler/util interfaces for the bridge) are
    // not shipped in the release, so they are resolved from the ordinary repositories.
    val versioned = os.walk(toolchain.repo().path).filter(_.ext == "jar").map(PathRef(_))
    val thirdParty = defaultResolver().classpath(Seq(
      mvn"org.scala-lang.modules:scala-asm:9.9.0-scala-1",
      mvn"org.scala-sbt:compiler-interface:1.12.0",
      mvn"org.scala-sbt:util-interface:1.11.5"))

    versioned ++ thirdParty

  override def scalaCompilerBridge: T[Option[PathRef]] = Task:
    Some(PathRef(toolchain.distribution().path / "scala3-sbt-bridge.jar"))

trait BaseScalaModule extends Toolchain:
  override def scalaVersion = settings.scalaVersion
  override def scalacOptions = settings.scalaOptions
  def consoleScalacOptions = scalacOptions()

  override def assemblyRules =
    super.assemblyRules :+ mill.javalib.Assembly.Rule.AppendPattern("META-INF/givens/.*")

  def publishVersion = Task:
    try
      val lastTagged = os.proc("git", "rev-list", "--tags", "--max-count", "1").call().out.text().trim
      os.proc("git", "describe", "--tags", lastTagged).call().out.text().trim
    catch case error: Exception => "unknown"

  override def docJar = Task:
    val jar = Task.dest / "empty.jar"
    val zos = new java.util.zip.ZipOutputStream(new java.io.FileOutputStream(jar.toIO))
    zos.close()
    PathRef(jar)

  def artifactSuffix = Task("")
  def pomSettings = Task(PomSettings(
    description = "soundness-all",
    organization = "dev.soundness",
    url = "https://soundness.dev/",
    licenses = Seq(License.`Apache-2.0`),
    versionControl = VersionControl.github("propensive", "soundness"),
    developers = Seq(Developer("propensive", "Jon Pretty", "https://github.com/propensive"))
  ))

trait Library extends Module:
  def moduleDir = super.moduleDir / ".." / "lib" / super.moduleDir.last / "src"

// Maps a component's JVM `moduleDeps` to the corresponding `.js` cross-modules, skipping any
// dependency that is not itself Scala.js-capable. A component whose closure is fully JS-capable
// therefore gets a complete JS dependency graph; one that (transitively) reaches a JVM-only module
// like `hellenism` will be missing that dependency and fail to compile — the signal to mark it
// `scalaJs = false` too.
def jsDeps(deps: Seq[mill.api.Module]): Seq[ScalaJSModule] = deps.collect:
  case component: Component if component.scalaJs         => component.js
  case component: BareComponent if component.scalaJs     => component.js

// The Scala Native counterpart of `jsDeps`: maps JVM `moduleDeps` to the corresponding `.native`
// cross-modules, skipping any dependency not itself Native-capable (`scalaNative = false`).
def nativeDeps(deps: Seq[mill.api.Module]): Seq[ScalaModule] = deps.collect:
  case component: Component if component.scalaNative     => component.native
  case component: BareComponent if component.scalaNative => component.native

// Adds nested `js` (Scala.js) and `native` (Scala Native) cross-modules that share the JVM
// module's sources, resources and scalac options — the compiler plugins and `-Yimports` etc.
// apply identically across platforms. `scalaJs` defaults on; `scalaNative` defaults to `scalaJs`,
// because a module's platform-neutrality is very nearly the same predicate for both back ends —
// so a JVM-only module (`scalaJs = false`) is native-incapable by default too, and only the few
// modules where the two diverge need an explicit `scalaNative` override (a JS-capable module that
// nonetheless uses a native-unsupported API, or a native materializer with no JS relevance). Opting
// a platform out also excludes the module from the `soundness.js` / `soundness.native` aggregates
// and from dependents' cross graphs.
//
// The `js` module is a real `ScalaJSModule` (mill's Scala.js worker links it). The `native` module
// is a plain `ScalaModule` whose Native-ness comes entirely from the `nscplugin` `-Xplugin` and the
// Native stdlib on its classpath: compiling it emits `.nir` alongside the classfiles. Linking a
// native binary is a separate step (`soundness.nativelink`), mirroring how the Wasm component is
// linked out of band.
trait PlatformCross extends BaseScalaModule:
  jvm =>
  def scalaJs: Boolean = true
  def scalaNative: Boolean = scalaJs
  def jsModuleDeps: Seq[ScalaJSModule]
  def nativeModuleDeps: Seq[ScalaModule]
  // The sources of the cross-modules: the JVM module's sources by default, overridable for
  // components with platform-specific implementations (e.g. `pneumatic.flate`).
  def jsSources: T[Seq[PathRef]] = sources
  def nativeSources: T[Seq[PathRef]] = sources

  object js extends ScalaJSModule, Toolchain:
    def scalaVersion = settings.scalaVersion
    def scalaJSVersion = settings.scalaJsVersion
    def scalacOptions = jvm.scalacOptions
    def sources = jvm.jsSources
    def resources = jvm.resources
    def compileResources = jvm.compileResources
    def mvnDeps = jvm.mvnDeps
    def compileMvnDeps = jvm.compileMvnDeps
    override def moduleDeps = jvm.jsModuleDeps

  object native extends ScalaModule, Toolchain:
    def scalaVersion = settings.scalaVersion
    def scalacOptions = Task:
      jvm.scalacOptions() :+ s"-Xplugin:${nativeToolchain.nscplugin().path}"
    def sources = jvm.nativeSources
    def resources = jvm.resources
    def compileResources = jvm.compileResources
    def mvnDeps = jvm.mvnDeps
    // The Native stdlib/`javalib` are compiled against directly (they carry the `.nir` the linker
    // consumes); the fork's JVM stdlib remains present for the compiler itself via `Toolchain`.
    def compileMvnDeps = Task { jvm.compileMvnDeps() ++ nativeToolchain.runtimeDeps }
    override def moduleDeps = jvm.nativeModuleDeps

trait BareComponent(dependencies: PublishModule*)
extends BaseScalaModule, SonatypeCentralPublishModule, PlatformCross:
  def moduleId: String = moduleDir.last
  def resources = Task.Sources(moduleDir / ".." / ".." / "res" / moduleId)
  def compileResources = Task.Sources(moduleDir / ".." / ".." / "res" / moduleId)
  def sources = Task.Sources(moduleDir)
  override def moduleDeps = dependencies
  def jsModuleDeps = jsDeps(moduleDeps)
  def nativeModuleDeps = nativeDeps(moduleDeps)

trait Component(dependencies: PublishModule*)
extends BaseScalaModule, SonatypeCentralPublishModule, PlatformCross:
  def moduleId: String = moduleDir.last
  def resources = Task.Sources(moduleDir / ".." / ".." / "res" / moduleId)
  def compileResources = Task.Sources(moduleDir / ".." / ".." / "res" / moduleId)
  def sources = Task.Sources(moduleDir)
  override def moduleDeps = beneficence.core +: proscenium.core +: dependencies
  def jsModuleDeps = jsDeps(moduleDeps)
  def nativeModuleDeps = nativeDeps(moduleDeps)

  override def scalacOptions = Task:
    settings.scalaOptions
      :+ s"-Xplugin:${decorum.plugin.assembly().path}"
      :+ s"-Xplugin:${beneficence.plugin.assembly().path}"
// Like `Component`, but not published to Maven Central. For demos, examples, and
// other modules that are built and tested but never released.
trait Internal(dependencies: JavaModule*) extends BaseScalaModule:
  def moduleId: String = moduleDir.last
  def resources = Task.Sources(moduleDir / ".." / ".." / "res" / moduleId)
  def compileResources = Task.Sources(moduleDir / ".." / ".." / "res" / moduleId)
  def sources = Task.Sources(moduleDir)
  override def moduleDeps: Seq[JavaModule] = beneficence.core +: proscenium.core +: dependencies

  override def scalacOptions = Task:
    settings.scalaOptions
      :+ s"-Xplugin:${decorum.plugin.assembly().path}"
      :+ s"-Xplugin:${beneficence.plugin.assembly().path}"
trait Tests(dependencies: JavaModule*) extends BaseScalaModule:
  def enabled: Boolean = true
  def moduleId: String = moduleDir.last
  def finalMainClass = (moduleDir / ".." / "..").last + ".Tests"
  def resources = Task.Sources(moduleDir / ".." / ".." / "res" / moduleId)
  def compileResources = Task.Sources(moduleDir / ".." / ".." / "res" / moduleId)
  // `larceny.plugin` supplies the `demilitarize`/`CompileError` symbols that test sources import
  // (`import larceny.*`); it is also applied as an `-Xplugin` below. This used to reach the test
  // classpath transitively via `chiaroscuro`, but chiaroscuro no longer depends on it (so it can
  // cross-compile to Scala.js), so the dependency is now explicit here.
  def moduleDeps: Seq[JavaModule] =
    larceny.plugin +: probably.cli +: proscenium.core +: dependencies
  def sources = Task.Sources(moduleDir)
  def consoleScalacOptions = scalacOptions()

  def scalacOptions = Task:
    settings.scalaOptions
      :+ s"-Xplugin:${larceny.plugin.assembly().path}"
      :+ s"-Xplugin:${beneficence.plugin.assembly().path}"
trait Benchmarks(dependencies: PublishModule*) extends BaseScalaModule:
  def moduleId: String = moduleDir.last
  def finalMainClass = (moduleDir / ".." / "..").last + ".Benchmarks"
  def resources = Task.Sources(moduleDir / ".." / ".." / "res" / moduleId)
  def compileResources = Task.Sources(moduleDir / ".." / ".." / "res" / moduleId)
  def moduleDeps: Seq[PublishModule] = probably.cli +: sedentary.core +: dependencies
  def sources = Task.Sources(moduleDir)
  def consoleScalacOptions = scalacOptions()

trait Bundle(dependencies: PublishModule*) extends BaseScalaModule, PublishModule:
  def sources = Task.Sources()
  def moduleDeps = dependencies

