package build

import mill.*
import mill.api.Result
import scalalib.*
import mill.scalajslib.*
import mill.scalajslib.api.*
import publish.*
import os.Path

object settings:
  // A locally-built Scala compiler from the propensive/scala fork: the `make` build of the
  // 3.9.0-RC1 tree merged with the capture-checking fix branches (currently
  // `feature/3.9.0/make-unboxedpure-splicealias-aliascap-ctxresult-castbox-permitlazy`; the
  // stock compiler mis-boxes pure values, mishandles quote type-holes, alias and
  // context-result capabilities, cast type-arguments, and cycles on JDK 25 sealed-classfile
  // parsing — see rep/DECISIONS.md). Build it with `make` in the fork worktree;
  // the `toolchain` module below exposes its `release/lib` jars to every coursier resolution,
  // so no publishing step is needed. Point `SOUNDNESS_SCALA_HOME` at a different `release`
  // directory to switch compilers. After rebuilding the compiler, run `./mill clean`: the
  // compiler and sbt-bridge paths are content-hashed, but coursier may serve other repo
  // artifacts from its cache under this unchanging version string.
  // `SOUNDNESS_SCALA_VERSION`/`SOUNDNESS_SCALA_HOME` switch toolchains together (the version
  // string must match what the `release` was built with, or coursier/zinc caches poison each
  // other across compilers). Defaults target the 3.9.0 row; the 3.10.0 row (tracking
  // upstream/main) lives at ../scala/all-main/release with version "3.10.0-propensive".
  val scalaVersion = sys.env.getOrElse("SOUNDNESS_SCALA_VERSION", "3.9.0-RC1-propensive")
  val scalaHome =
    sys.env.getOrElse
      ("SOUNDNESS_SCALA_HOME", "/Users/propensive/work/worktrees/scala/soundness-390/release")
  val scalaJsVersion = "1.20.2"
  val scalaOptions = Seq(
    "-experimental",
    "-new-syntax",
    "-feature",
    "-preview",
    //"-explain",
    "-deprecation",
    "-Wunused:imports",
    "-Wimplausible-patterns",
    // Suppress `-Wunused:imports` false positives on given/capability marker imports that
    // dotty's usage tracking misses: the import is load-bearing (removing it breaks
    // compilation), so it is silenced narrowly by `origin` (the imported symbol's path).
    "-Wconf:origin=.*unsafeExceptions.canThrowAny:s",
    "-Wconf:origin=.*strategies.throwUnsafely:s",
    "-Wconf:origin=.*hashProviders.soundnessHashing:s",
    "-Wconf:origin=.*charEncoders.ascii:s",
    "-Wconf:origin=.*textMetrics.uniform:s",
    "-Wconf:origin=.*arithmeticOptions.overflow.unchecked:s",
    "-Wconf:origin=.*errorDiagnostics.empty:s",
    "-Wconf:origin=.*logging.silent:s",
    "-Wconf:origin=.*pathOnLinux:s",
    "-Wconf:origin=.*systems.java:s",
    "-Wconf:origin=.*overwritePreexisting.enabled:s",
    "-Wconf:origin=.*dynamicJsonAccess.enabled:s",
    "-Wconf:origin=.*dynamicTelAccess.enabled:s",
    "-Wconf:origin=.*queryParameters.arbitraryQueryParameter:s",
    "-Wconf:origin=.*CssClass.nominative:s",
    "-Wconf:origin=.*Async.nominative:s",
    // `frames` is deliberately `inline` so the anonymous `Iterator` expands (with the by-name
    // `frame` thunk and the caller's `Cursor` operand-type refinement) at each call site.
    "-Wconf:src=.*obligatory.Framable.*&msg=anonymous class:s",
    // `whereas` applies a deliberately-partial `PartialFunction` as a total function; the unmatched
    // exceptions are routed to the trailing `.recover`, so the match is intentionally non-exhaustive.
    "-Wconf:src=.*synesthesia.McpServer.*&msg=match may not be exhaustive:s",
    // "-Wsafe-init",
    "-Xmax-inlines", "32",
    //"-Ycc-new",
    "-Yno-flexible-types",
    "-Yexplicit-nulls",
    "-Ycheck-all-patmat",
    // "-explain-cyclic",
    "-language:experimental.modularity",
    "-language:experimental.dependent",
    "-language:experimental.relaxedLambdaSyntax",
    "-language:experimental.genericNumberLiterals",
    "-language:experimental.into",
    "-language:experimental.erasedDefinitions",
    //"-language:experimental.packageObjectValues",
    "-language:implicitConversions",
    "-language:experimental.saferExceptions",
    "-language:experimental.strictEqualityPatternMatching",
    "-language:experimental.subCases",
    "-language:experimental.multiSpreads"
  )

  val scalaOptionsCC = scalaOptions ++ Seq("-Ycc-new")

  // Append the capture-checking flags to an existing options list. Enabling capture
  // checking is being rolled out module-by-module, bottom-up through the dependency
  // graph; a module opts in by routing its `scalacOptions` through this. The language
  // flag is equivalent to a per-file `import language.experimental.captureChecking`, so
  // no source edits are needed to switch a module on.
  def cc(options: Seq[String]): Seq[String] =
    options ++ Seq("-Ycc-new", "-language:experimental.captureChecking")

  // Capture checking plus separation checking: `consume` linearity, hidden-set
  // separation and `freeze` are only diagnosed in units compiled with this flag,
  // so a module holding exclusive capabilities is not actually checked for
  // single ownership until it routes through `sep`. Rolled out module-by-module
  // like `cc`; the flag subsumes the per-file
  // `import language.experimental.separationChecking`.
  def sep(options: Seq[String]): Seq[String] =
    cc(options) :+ "-language:experimental.separationChecking"

  // Override `-Xmax-inlines` to `limit`, replacing any existing setting rather
  // than appending a second one (which the compiler reports as "Option
  // -Xmax-inlines was updated"). The base stays 32 everywhere else.
  def maxInlines(options: Seq[String], limit: String): Seq[String] =
    def strip(remaining: List[String]): List[String] = remaining match
      case "-Xmax-inlines" :: _ :: rest => strip(rest)
      case other :: rest                => other :: strip(rest)
      case Nil                          => Nil

    strip(options.to(List)) ++ Seq("-Xmax-inlines", limit)

// Exposes the fork compiler's `release/lib` directory (see `settings.scalaHome`) as a
// Maven-layout repository, generated on demand into the task's own dest: the unversioned jars
// are copied to versioned coordinates with minimal POMs. Everything coursier resolves for
// `settings.scalaVersion` — the unified `scala-library` (force-versioned into every module's
// resolution), `scala3-compiler_3` (including the modules that depend on the compiler API),
// `scala3-staging_3`, the sbt bridge, and the Scala.js stdlib — is served from here.
object toolchain extends Module:
  // Content-fingerprints the fork's jars so a rebuilt compiler regenerates the repository.
  def distribution: T[PathRef] = Task.Input:
    PathRef(os.Path(settings.scalaHome) / "lib")

  def repo: T[PathRef] = Task:
    val lib = distribution().path
    val v = settings.scalaVersion
    val sl = "org.scala-lang"
    val sjs = "org.scala-js"

    // (group, artifactId, jar filename in release/lib, dependencies as (group, id, version))
    val artifacts = Seq(
      (sl, "scala-library", "scala-library.jar", Seq()),
      (sl, "scala3-library_3", "scala3-library.jar", Seq((sl, "scala-library", v))),
      (sl, "scala3-interfaces", "scala3-interfaces.jar", Seq()),
      (sl, "tasty-core_3", "tasty-core.jar", Seq((sl, "scala-library", v))),
      (sl, "scala3-compiler_3", "scala3-compiler.jar", Seq(
        (sl, "scala3-interfaces", v),
        (sl, "tasty-core_3", v),
        (sl, "scala3-library_3", v),
        ("org.scala-lang.modules", "scala-asm", "9.9.0-scala-1"),
        ("org.scala-sbt", "compiler-interface", "1.10.7"),
        ("org.scala-sbt", "util-interface", "1.10.7"))),
      (sl, "scala3-repl_3", "scala3-repl.jar", Seq(
        (sl, "scala3-compiler_3", v),
        ("org.jline", "jline-reader", "3.29.0"),
        ("org.jline", "jline-terminal", "3.29.0"),
        ("org.jline", "jline-terminal-jni", "3.29.0"),
        ("io.get-coursier", "interface", "1.0.28"),
        ("org.virtuslab", "using_directives", "1.1.4"),
        ("com.lihaoyi", "pprint_3", "0.9.3"))),
      (sl, "scala3-sbt-bridge", "scala3-sbt-bridge.jar", Seq(
        (sl, "scala3-compiler_3", v),
        (sl, "scala3-repl_3", v))),
      (sl, "scala3-staging_3", "scala3-staging.jar", Seq((sl, "scala3-compiler_3", v))),
      (sl, "scala3-tasty-inspector_3", "scala3-tasty-inspector.jar", Seq(
        (sl, "scala3-compiler_3", v))),
      (sjs, "scalajs-scalalib_2.13", "scalajs-scalalib_2.13.jar", Seq(
        (sjs, "scalajs-javalib", settings.scalaJsVersion))),
      (sl, "scala3-library_sjs1_3", "scala3-library_sjs1.jar", Seq(
        (sl, "scala-library", v),
        (sjs, "scalajs-library_2.13", settings.scalaJsVersion),
        (sjs, "scalajs-scalalib_2.13", v))))

    artifacts.map: (group, id, jar, dependencies) =>
      val dir = Task.dest / os.SubPath(group.replace('.', '/')) / id / v
      os.makeDir.all(dir)
      os.copy(lib / jar, dir / s"$id-$v.jar", replaceExisting = true)

      val deps = dependencies.map: (dGroup, dId, dVersion) =>
        s"<dependency><groupId>$dGroup</groupId><artifactId>$dId</artifactId>" +
          s"<version>$dVersion</version></dependency>"
      . mkString

      os.write.over(dir / s"$id-$v.pom",
        s"""<?xml version="1.0" encoding="UTF-8"?>
           |<project xmlns="http://maven.apache.org/POM/4.0.0">
           |  <modelVersion>4.0.0</modelVersion>
           |  <groupId>$group</groupId>
           |  <artifactId>$id</artifactId>
           |  <version>$v</version>
           |  <dependencies>$deps</dependencies>
           |</project>
           |""".stripMargin)

    PathRef(Task.dest)

// Routes a Scala module through the fork toolchain: the repository view above for all coursier
// resolutions, plus direct (content-hashed) paths for the two hot artifacts — the compiler
// classpath and the compiled sbt bridge — so a rebuilt compiler is picked up without any
// version-string ceremony.
trait Toolchain extends ScalaModule:
  override def repositories: T[Seq[String]] = Task:
    super.repositories() :+ s"file://${toolchain.repo().path}"

  override def scalaCompilerClasspath: T[Seq[PathRef]] = Task:
    // The fork-built jars come from the repository view because Zinc locates the standard
    // library within this classpath BY FILENAME (`scala-library-<version>*.jar`), and the
    // distribution's own filenames are unversioned. Third-party jars (already versioned
    // filenames) come straight from the distribution.
    val versioned = os.walk(toolchain.repo().path).filter(_.ext == "jar")
    val thirdParty =
      os.list(toolchain.distribution().path).filter: jar =>
        jar.ext == "jar" && jar.baseName.exists(_.isDigit)

    (versioned ++ thirdParty).map(PathRef(_))

  override def scalaCompilerBridge: T[Option[PathRef]] = Task:
    Some(PathRef(toolchain.distribution().path / "scala3-sbt-bridge.jar"))

trait BaseScalaModule extends Toolchain:
  override def scalaVersion = settings.scalaVersion
  override def scalacOptions = settings.scalaOptions
  def consoleScalacOptions = scalacOptions()

  override def assemblyRules =
    super.assemblyRules :+ mill.javalib.Assembly.Rule.AppendPattern("META-INF/givens/.*")

  def publishVersion = Task:
    try
      val lastTagged = os.proc("git", "rev-list", "--tags", "--max-count", "1").call().out.text().trim
      os.proc("git", "describe", "--tags", lastTagged).call().out.text().trim
    catch case error: Exception => "unknown"

  override def docJar = Task:
    val jar = Task.dest / "empty.jar"
    val zos = new java.util.zip.ZipOutputStream(new java.io.FileOutputStream(jar.toIO))
    zos.close()
    PathRef(jar)

  def artifactSuffix = Task("")
  def pomSettings = Task(PomSettings(
    description = "soundness-all",
    organization = "dev.soundness",
    url = "https://soundness.dev/",
    licenses = Seq(License.`Apache-2.0`),
    versionControl = VersionControl.github("propensive", "soundness"),
    developers = Seq(Developer("propensive", "Jon Pretty", "https://github.com/propensive"))
  ))

trait Library extends Module:
  def moduleDir = super.moduleDir / ".." / "lib" / super.moduleDir.last / "src"

// Maps a component's JVM `moduleDeps` to the corresponding `.js` cross-modules, skipping any
// dependency that is not itself Scala.js-capable. A component whose closure is fully JS-capable
// therefore gets a complete JS dependency graph; one that (transitively) reaches a JVM-only module
// like `hellenism` will be missing that dependency and fail to compile — the signal to mark it
// `scalaJs = false` too.
def jsDeps(deps: Seq[mill.api.Module]): Seq[ScalaJSModule] = deps.collect:
  case component: Component if component.scalaJs         => component.js
  case component: BareComponent if component.scalaJs     => component.js

// Adds a nested `js` Scala.js cross-module that shares the JVM module's sources, resources and
// scalac options (the compiler plugins and `-Yimports` etc. apply identically; mill appends
// `-scalajs`). On by default; a JVM-only module opts out with `override def scalaJs = false`, which
// also excludes it from `jsAll` and from dependents' JS dependency graphs.
trait ScalaJsCross extends BaseScalaModule:
  jvm =>
  def scalaJs: Boolean = true
  def jsModuleDeps: Seq[ScalaJSModule]

  object js extends ScalaJSModule, Toolchain:
    def scalaVersion = settings.scalaVersion
    def scalaJSVersion = settings.scalaJsVersion
    def scalacOptions = jvm.scalacOptions
    def sources = jvm.sources
    def resources = jvm.resources
    def compileResources = jvm.compileResources
    def mvnDeps = jvm.mvnDeps
    def compileMvnDeps = jvm.compileMvnDeps
    override def moduleDeps = jvm.jsModuleDeps

trait BareComponent(dependencies: PublishModule*)
extends BaseScalaModule, SonatypeCentralPublishModule, ScalaJsCross:
  def moduleId: String = moduleDir.last
  def resources = Task.Sources(moduleDir / ".." / ".." / "res" / moduleId)
  def compileResources = Task.Sources(moduleDir / ".." / ".." / "res" / moduleId)
  def sources = Task.Sources(moduleDir)
  override def moduleDeps = dependencies
  def jsModuleDeps = jsDeps(moduleDeps)

trait Component(dependencies: PublishModule*)
extends BaseScalaModule, SonatypeCentralPublishModule, ScalaJsCross:
  def moduleId: String = moduleDir.last
  def resources = Task.Sources(moduleDir / ".." / ".." / "res" / moduleId)
  def compileResources = Task.Sources(moduleDir / ".." / ".." / "res" / moduleId)
  def sources = Task.Sources(moduleDir)
  override def moduleDeps = beneficence.core +: proscenium.core +: dependencies
  def jsModuleDeps = jsDeps(moduleDeps)

  override def scalacOptions = Task:
    settings.scalaOptions
      :+ s"-Xplugin:${decorum.plugin.assembly().path}"
      :+ s"-Xplugin:${beneficence.plugin.assembly().path}"
// Like `Component`, but not published to Maven Central. For demos, examples, and
// other modules that are built and tested but never released.
trait Internal(dependencies: JavaModule*) extends BaseScalaModule:
  def moduleId: String = moduleDir.last
  def resources = Task.Sources(moduleDir / ".." / ".." / "res" / moduleId)
  def compileResources = Task.Sources(moduleDir / ".." / ".." / "res" / moduleId)
  def sources = Task.Sources(moduleDir)
  override def moduleDeps: Seq[JavaModule] = beneficence.core +: proscenium.core +: dependencies

  override def scalacOptions = Task:
    settings.scalaOptions
      :+ s"-Xplugin:${decorum.plugin.assembly().path}"
      :+ s"-Xplugin:${beneficence.plugin.assembly().path}"
trait Tests(dependencies: JavaModule*) extends BaseScalaModule:
  def enabled: Boolean = true
  def moduleId: String = moduleDir.last
  def finalMainClass = (moduleDir / ".." / "..").last + ".Tests"
  def resources = Task.Sources(moduleDir / ".." / ".." / "res" / moduleId)
  def compileResources = Task.Sources(moduleDir / ".." / ".." / "res" / moduleId)
  // `larceny.plugin` supplies the `demilitarize`/`CompileError` symbols that test sources import
  // (`import larceny.*`); it is also applied as an `-Xplugin` below. This used to reach the test
  // classpath transitively via `chiaroscuro`, but chiaroscuro no longer depends on it (so it can
  // cross-compile to Scala.js), so the dependency is now explicit here.
  def moduleDeps: Seq[JavaModule] =
    larceny.plugin +: probably.cli +: proscenium.core +: dependencies
  def sources = Task.Sources(moduleDir)
  def consoleScalacOptions = scalacOptions()

  def scalacOptions = Task:
    settings.scalaOptions
      :+ s"-Xplugin:${larceny.plugin.assembly().path}"
      :+ s"-Xplugin:${beneficence.plugin.assembly().path}"
trait Benchmarks(dependencies: PublishModule*) extends BaseScalaModule:
  def moduleId: String = moduleDir.last
  def finalMainClass = (moduleDir / ".." / "..").last + ".Benchmarks"
  def resources = Task.Sources(moduleDir / ".." / ".." / "res" / moduleId)
  def compileResources = Task.Sources(moduleDir / ".." / ".." / "res" / moduleId)
  def moduleDeps: Seq[PublishModule] = probably.cli +: sedentary.core +: dependencies
  def sources = Task.Sources(moduleDir)
  def consoleScalacOptions = scalacOptions()

trait Bundle(dependencies: PublishModule*) extends BaseScalaModule, PublishModule:
  def sources = Task.Sources()
  def moduleDeps = dependencies

// ------------------------ GROUPS ------------------------
