object pneumatic extends Library:
  // The typeclasses, the pure-Scala implementations (LZW, Brotli, and the DEFLATE machinery
  // ported from JZlib), and the engine interfaces the `flate` formats compile against. Compiled
  // with capture checking (not separation checking): the faithfully-ported, aliasing-heavy zlib
  // machinery does not (yet) satisfy the stricter ruleset.
  object core extends Component(turbulence.core):
    override def scalacOptions = Task:
      settings.cc(super.scalacOptions() ++ Seq("-Yno-predef", "-Yimports:java.lang,scala,proscenium"))
  // The `Deflate`/`Gzip`/`Zlib` formats, compiled twice against platform backends: over
  // `java.util.zip` (native zlib) on the JVM, and over `core`'s pure-Scala port everywhere else
