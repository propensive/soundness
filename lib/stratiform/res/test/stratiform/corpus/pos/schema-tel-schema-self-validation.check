    line_endings: LF,
    children: [
        Block {
            comments: [
                Comment {
                    text: "The TEL schema-for-schemas (v1.0). Self-describing: parsing this document",
                },
                Comment {
                    text: "under the schema it defines yields a valid semantic model. The vocabulary",
                },
                Comment {
                    text: "and surface conventions are specified in §20.5 of the TEL Specification.",
                },
                Comment {
                    text: "",
                },
                Comment {
                    text: "Naming. Every Definition is a PascalCase TypeName; every variant or field",
                },
                Comment {
                    text: "keyword is kebab-case. The two grammars are disjoint by leading letter case",
                },
                Comment {
                    text: "(§20.7).",
                },
                Comment {
                    text: "",
                },
                Comment {
                    text: "Polarity. The default for every Field and SelectRef is required and",
                },
                Comment {
                    text: "irrepeatable. `optional`/`repeatable` (Flag fields) loosen on the base side;",
                },
                Comment {
                    text: "`required`/`irrepeatable` re-tighten on the layer side (§20 surface",
                },
                Comment {
                    text: "syntax).",
                },
                Comment {
                    text: "",
                },
                Comment {
                    text: "Type references. Every `field type` and `variant type` atom, and every",
                },
                Comment {
                    text: "SelectRef's first inline atom, is a TypeName that resolves through the",
                },
                Comment {
                    text: "composed Definition namespace to a record, scalar, select, or built-in",
                },
                Comment {
                    text: "(`Flag`, `String`, `Identifier`, `Sigil`).",
                },
            ],
            tabulation: None,
            compounds: [
                Compound {
                    keyword: "name",
                    atoms: [
                        Inline {
                            text: "tel-schema",
                            preceding_spaces: 1,
