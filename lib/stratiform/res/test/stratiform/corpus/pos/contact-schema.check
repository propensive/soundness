        Block {
            comments: [
                Comment {
                    text: "A worked example of a TEL schema: a \"contact\" record type.",
                },
                Comment {
                    text: "",
                },
                Comment {
                    text: "Demonstrates the constructs an everyday schema author will reach for:",
                },
                Comment {
                    text: "",
                },
                Comment {
                    text: "  - required and optional `field`s of named scalar types (`String`)",
                },
                Comment {
                    text: "  - a `repeatable` field (`phone`)",
                },
                Comment {
                    text: "  - named `record`s (`PhoneNumber`, `Address`) referenced from",
                },
                Comment {
                    text: "    multiple positions",
                },
                Comment {
                    text: "  - a named top-level `select` (`Status`) with all-`Flag` variants,",
                },
                Comment {
                    text: "    placed as a `SelectRef` at the use site so it can also be set",
                },
                Comment {
                    text: "    inline as an atom on the parent compound",
                },
                Comment {
                    text: "  - a per-field `default` value (`country`)",
                },
                Comment {
                    text: "",
                },
                Comment {
                    text: "Every `field` and `variant` carries its type as an inline atom after",
                },
                Comment {
                    text: "any flags; type names are PascalCase and resolve to either a user-",
                },
                Comment {
                    text: "declared `record`/`scalar`/`select` or one of the predefined names",
                },
                Comment {
                    text: "`Flag`, `String`, `Identifier`, `Sigil`.",
                },
                Comment {
                    text: "",
                },
                Comment {
                    text: "To see what a document conforming to this schema looks like, see the",
                },
                Comment {
                    text: "accompanying `contact-document.tel`. This schema document is itself",
                },
                Comment {
                    text: "validated against the tel-schema (the schema-for-schemas) at parse time.",
                },
            ],
